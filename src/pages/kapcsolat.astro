---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kapcsolat & Időpontfoglalás | McKenzie Gyógytorna Rendelő Budapest"
  description="Foglaljon időpontot McKenzie gyógytorna kezelésre Budapesten. Két helyszín: Belváros (Sas u. 7.) és Bel-Buda (Bartók Béla út 34.). Telefon: (30) 487-8284."
>
  <!-- Header -->
  <section class="pt-32 pb-16 bg-gradient-to-br from-navy-950 via-navy-900 to-teal-700">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-white">Kapcsolat & Időpontfoglalás</h1>
      <p class="mt-4 text-gray-300 text-lg">Válassza ki az Önnek megfelelő helyszínt</p>
    </div>
  </section>

  <!-- Phone CTA -->
  <section id="idopontfoglalas" class="relative -mt-8 z-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-2xl shadow-xl shadow-black/5 p-6 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <p class="font-heading text-xl font-bold text-navy-900">Időpontfoglalás telefonon</p>
          <p class="text-gray-500 text-sm">Hétköznapokon 9:00-17:00 között</p>
        </div>
        <a href="tel:+36304878284" class="inline-flex items-center gap-3 px-8 py-4 bg-gold-500 hover:bg-gold-600 text-white font-bold text-lg rounded-full transition-all hover:shadow-lg hover:shadow-gold-500/25">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          (30) 487-8284
        </a>
      </div>
    </div>
  </section>

  <!-- Két helyszín -->
  <section class="py-20 bg-warm-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <!-- Belváros -->
        <div class="reveal bg-white rounded-3xl overflow-hidden shadow-lg border border-gray-100">
          <div class="h-64 bg-gradient-to-br from-teal-600 to-teal-500 flex items-center justify-center">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2695.5!2d19.0505!3d47.5025!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4741dc43d tried!2sSas+u.+7%2C+Budapest%2C+1051!5e0!3m2!1shu!2shu"
              width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
              referrerpolicy="no-referrer-when-downgrade" title="Belvárosi rendelő térkép">
            </iframe>
          </div>
          <div class="p-8">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-teal-50 rounded-full mb-4">
              <span class="text-teal-700 text-sm font-semibold">Belvárosi rendelő</span>
            </div>
            <h3 class="font-heading text-2xl font-bold text-navy-900">Bazilika környéke</h3>

            <div class="mt-6 space-y-4 text-sm">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-teal-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <div>
                  <p class="font-semibold text-navy-900">1051 Budapest, Sas u. 7.</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-teal-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div>
                  <p class="font-semibold text-navy-900">Hétköznapokon 8:00 – 20:00</p>
                  <p class="text-gray-500">Csak előzetes bejelentkezés alapján</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-teal-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div>
                  <p class="text-gray-600">Deák Ferenc tér metró 6-8 perc, Arany János M3 ~5 perc</p>
                  <p class="text-gray-600">Parkolás: Bazilika garázs, Gödör</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Bel-Buda -->
        <div class="reveal stagger-2 bg-white rounded-3xl overflow-hidden shadow-lg border border-gray-100">
          <div class="h-64 bg-gradient-to-br from-navy-700 to-navy-600 flex items-center justify-center">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2696.0!2d19.0455!3d47.4740!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sBart%C3%B3k+B%C3%A9la+%C3%BAt+34%2C+Budapest%2C+1111!5e0!3m2!1shu!2shu"
              width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
              referrerpolicy="no-referrer-when-downgrade" title="Bel-budai rendelő térkép">
            </iframe>
          </div>
          <div class="p-8">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-navy-50 rounded-full mb-4">
              <span class="text-navy-700 text-sm font-semibold">Bel-budai rendelő</span>
            </div>
            <h3 class="font-heading text-2xl font-bold text-navy-900">Móricz Zsigmond körtér</h3>

            <div class="mt-6 space-y-4 text-sm">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-navy-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <div>
                  <p class="font-semibold text-navy-900">1111 Budapest, Bartók Béla út 34. I.em.1.</p>
                  <p class="text-gray-500">18-as kapucsengő</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-navy-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div>
                  <p class="font-semibold text-navy-900">Hétköznapokon 8:00 – 20:00</p>
                  <p class="text-gray-500">Csak előzetes bejelentkezés alapján</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-navy-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div>
                  <p class="text-gray-600">M4 metró Móricz Zsigmond körtér ~5 perc</p>
                  <p class="text-gray-600">Villamosok: 19, 41, 47, 48, 49, 56, 6, 61</p>
                  <p class="text-gray-600">Parkolás: Allee garázs 6-8 perc</p>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Mire számítson -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="reveal font-heading text-3xl font-bold text-navy-900 text-center gold-line-center">Mire számítson az első alkalommal?</h2>
      <div class="mt-12 space-y-8">
        {[
          { step: '1', title: 'Mozgásvizsgálat', desc: 'A gyógytornász felméri az Ön mozgásterjedelmét, fájdalmát és annak viselkedését különböző mozgásokra.' },
          { step: '2', title: 'Kezelési terv', desc: 'Az eredmények alapján személyre szabott kezelési tervet állít össze, amelyet közösen megbeszélünk.' },
          { step: '3', title: 'Első kezelés + otthoni gyakorlatok', desc: 'Megkapja az első kezelést és az otthoni gyakorlatsort, amit a következő alkalomig végezhet.' },
        ].map((item, i) => (
          <div class={`reveal stagger-${i + 1} flex items-start gap-5`}>
            <div class="w-10 h-10 rounded-full bg-teal-600 flex items-center justify-center shrink-0">
              <span class="text-white font-bold">{item.step}</span>
            </div>
            <div>
              <h3 class="font-heading text-xl font-bold text-navy-900">{item.title}</h3>
              <p class="mt-1 text-gray-600">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
