---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const starSvg = '<svg class="w-5 h-5 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';

const featured = [
  {
    text: 'Mostanában semmi bajom. Mégis jövök. Miért? Kelleni kell valakinek. Testileg is, lelkileg is. Relle Éva az, aki mindkettőt adja. Náluk megkapom a testileg és lelkileg egyaránt szükséges törődést.',
    name: 'Havas Henrik',
    role: 'újságíró',
    initials: 'HH',
    color: 'navy',
  },
  {
    text: 'Nincs gerincsérvből eredő kilátástalanság. A McKenzie-módszerrel gyakorlatilag visszakaptam az életem. Tiszta szívből ajánlom mindenkinek, aki hasonló problémával küzd!',
    name: 'Kulcsár Krisztián',
    role: 'világbajnok vívó',
    initials: 'KK',
    color: 'teal',
  },
];

const reviews = [
  {
    text: 'A fájdalommentes életet jelenti az itt kapott kezelés. Professzionális ellátás, barátságos légkör, rendkívül hozzáértő gyógytornász!',
    name: 'Dr. Utassyné Kormos Zsuzsa',
    role: 'páciens',
    initials: 'UK',
  },
  {
    text: 'Az izmokat újra feléleszteni segített, és a baleset előtti szintre hozni. Két kezelés után már éreztem a javulást, az otthoni gyakorlatok rendszeres végzésével azóta is panaszmentes vagyok.',
    name: 'S. Attila',
    role: 'páciens, 2009',
    initials: 'SA',
  },
  {
    text: 'Eszterrel élmény a gyógytorna is! Nagyon alapos és felkészült szakember. Először sport okozta deréksérüléssel kerestem fel. A közös munka lényegretörő és következetes volt, néhány hónapon belül érezhető volt a javulás. És a legfontosabb, hogy torna közben a nevetés sem marad el!',
    name: 'Izsák Eszter',
    role: 'páciens',
    initials: 'IE',
  },
  {
    text: 'Eszterhez egy évtizedes gerincfájdalom miatt jártam. Nagy körültekintéssel segített megtalálni a forrásokat, és olyan gyakorlatokkal és tanácsokkal látott el, amiket a mai napig használok, és működnek. Szívből ajánlom!',
    name: 'Kele Zsolt',
    role: 'páciens',
    initials: 'KZ',
  },
  {
    text: 'Deréktáji és vállpanaszokkal kerestem fel a rendelőt. Eszter professzionális felkészültségének és empatikus hozzáállásának köszönhetően rengeteg gyakorlatot tanultam. A gyakorlatsor a visszajelzéseim alapján minden alkalommal aktualizálva lett.',
    name: 'Szabó Péter',
    role: 'páciens',
    initials: 'SZP',
  },
  {
    text: 'Hihetetlenül hálás vagyok, nagyon sokat segítettek az eredeti problémámon. Eszter mély tudással rendelkezik, nagyon profi. Mindent elmagyaráz a „miértről" a „hogyanig". Inspirál, támogat, buzdít. Nagyon jó érzés ilyen jó kezekben lenni!',
    name: 'Audrey',
    role: 'páciens',
    initials: 'A',
  },
  {
    text: 'Eszti szuper szaktudással rendelkezik. Két hét alatt járóképessé varázsolt két kiszakadt porckorong sérvvel. Már három éve járok hozzá karbantartásra. Összeállította az otthoni gyakorlataimat, figyelembe véve az állapotom változásait.',
    name: 'Balla Zoltán',
    role: 'páciens',
    initials: 'BZ',
  },
  {
    text: 'Magas színvonalú szolgáltatást kapok elérhető áron. Csak ajánlani és dicsérni tudom a rendelőt és az összes gyógytornászt!',
    name: 'Anonim páciens',
    role: 'visszajelző kérdőív',
    initials: '★',
  },
  {
    text: 'Vágó Eszternél volt a lányom. Alapos, jó szakember és nagyon kedves.',
    name: 'Füzesi Katalin',
    role: 'páciens',
    initials: 'FK',
  },
];

const press = [
  {
    title: 'McKenzie módszer a gerincproblémák gyógyítására',
    source: 'Sikeres Nők',
    issue: 'XI. évf. 2008. április, 123. szám',
    quote: 'Ha időben lépünk, elkerülhetjük a bajt, megelőzhetjük a kiújuló fájdalmakat.',
  },
  {
    title: 'Gyakorlatok derékfájás ellen',
    source: 'Nők Lapja Egészség',
    issue: 'V. évf. 4-5-6. szám, 2011',
    quote: 'Az esetek 80%-ában a derékfájás kiújuló jellegű betegség.',
  },
  {
    title: 'Derék dolog hátfájásra',
    source: 'Elixír Magazin',
    issue: '2011. szeptember',
    quote: 'A McKenzie-módszer a gerincproblémák speciális vizsgálati és kezelési rendszere.',
  },
  {
    title: 'McKenzie-módszer — Egyszerű mozdulatokkal a fájdalommentes életért',
    source: 'Phoenix Pharma',
    issue: '2010. május',
    quote: '',
  },
  {
    title: 'Az irodai munka veszélyei',
    source: 'Pályacsúcs Magazin',
    issue: '2010. február',
    quote: '',
  },
];

const tv = [
  { title: 'Esés megelőzés', date: '2014. november 10.' },
  { title: 'Csontrikula', date: '2015. január 15.' },
  { title: 'Térdsérülések', date: '2015. október 13.' },
];
---

<BaseLayout
  title="Vélemények és sajtó | McKenzie Gyógytorna Rendelő Budapest"
  description="Pácienseink véleményei, sajtómegjelenések és TV szereplések. 5.0 Google értékelés. Havas Henrik, Kulcsár Krisztián és számos elégedett páciens ajánlása."
>
  <!-- Header -->
  <section class="pt-32 pb-16 bg-gradient-to-br from-navy-950 via-navy-900 to-teal-700">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-white">Vélemények & Sajtó</h1>
      <div class="flex items-center justify-center gap-3 mt-6">
        <div class="flex">
          {[1,2,3,4,5].map(() => (
            <svg class="w-7 h-7 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
        <span class="text-white font-semibold text-xl">5.0</span>
        <span class="text-gray-300 text-lg">a Google-on</span>
      </div>
      <p class="mt-4 text-gray-400">Ismert személyiségek és elégedett páciensek ajánlásával</p>
    </div>
  </section>

  <!-- KIEMELT VÉLEMÉNYEK -->
  <section class="py-20 bg-warm-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Big 2 featured -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">
        {featured.map((f, i) => (
          <div class={`reveal stagger-${i + 1} relative bg-white rounded-3xl p-10 border-2 border-gold-200 shadow-xl`}>
            <div class="absolute -top-4 -left-2">
              <svg class="w-16 h-16 text-gold-200" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H0z"/></svg>
            </div>
            <div class="relative">
              <div class="flex items-center gap-1 mb-6">
                {[1,2,3,4,5].map(() => <svg class="w-5 h-5 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}
              </div>
              <blockquote class="text-gray-800 text-lg leading-relaxed italic font-heading">
                &bdquo;{f.text}&rdquo;
              </blockquote>
              <div class="mt-8 flex items-center gap-4">
                <div class={`w-14 h-14 rounded-full flex items-center justify-center font-bold text-lg ${f.color === 'navy' ? 'bg-navy-100 text-navy-700' : 'bg-teal-100 text-teal-700'}`}>
                  {f.initials}
                </div>
                <div>
                  <p class="font-bold text-navy-900 text-lg">{f.name}</p>
                  <p class="text-gray-500">{f.role}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Páciens vélemények -->
      <div class="mb-6">
        <h2 class="reveal font-heading text-3xl font-bold text-navy-900 gold-line">Pácienseink mondják</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-20">
        {reviews.map((r, i) => (
          <div class={`reveal stagger-${(i % 3) + 1} bg-white rounded-2xl p-7 border border-gray-100 hover:shadow-lg hover:border-teal-200 transition-all duration-300`}>
            <div class="flex items-center gap-1 mb-4">
              {[1,2,3,4,5].map(() => <svg class="w-4 h-4 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}
            </div>
            <blockquote class="text-gray-600 leading-relaxed italic">
              &bdquo;{r.text}&rdquo;
            </blockquote>
            <div class="mt-5 flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-warm-200 flex items-center justify-center text-gray-600 font-bold text-xs shrink-0">
                {r.initials}
              </div>
              <div>
                <p class="font-semibold text-navy-900 text-sm">{r.name}</p>
                <p class="text-xs text-gray-500">{r.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- SAJTÓMEGJELENÉSEK -->
      <div class="mb-8">
        <h2 class="reveal font-heading text-3xl font-bold text-navy-900 gold-line">Sajtómegjelenések</h2>
        <p class="reveal stagger-1 mt-3 text-gray-500">Országos lapokban és magazinokban jelentek meg cikkeink</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-16">
        {press.map((p, i) => (
          <div class={`reveal stagger-${(i % 2) + 1} bg-white rounded-2xl p-6 border border-gray-100 hover:shadow-md transition-shadow`}>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-navy-50 flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-navy-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-navy-900">{p.title}</h3>
                <p class="text-sm text-teal-600 font-medium mt-1">{p.source}</p>
                <p class="text-xs text-gray-400 mt-0.5">{p.issue}</p>
                {p.quote && (
                  <p class="text-gray-500 text-sm italic mt-3">&bdquo;{p.quote}&rdquo;</p>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- TV SZEREPLÉSEK -->
      <div class="mb-8">
        <h2 class="reveal font-heading text-3xl font-bold text-navy-900 gold-line">TV szereplések</h2>
        <p class="reveal stagger-1 mt-3 text-gray-500">MTV1 Családbarát Magazinműsor — szakértői szereplések</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-16">
        {tv.map((t, i) => (
          <div class={`reveal stagger-${i + 1} bg-white rounded-2xl p-6 border border-gray-100 text-center`}>
            <div class="w-14 h-14 mx-auto rounded-full bg-teal-50 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="font-heading font-bold text-navy-900">{t.title}</h3>
            <p class="text-sm text-gray-500 mt-1">MTV1 Családbarát</p>
            <p class="text-xs text-gray-400 mt-1">{t.date}</p>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="reveal text-center py-8">
        <div class="bg-gradient-to-br from-navy-900 to-navy-800 rounded-3xl p-10 lg:p-14 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-60 h-60 bg-teal-500/10 rounded-full blur-3xl"></div>
          <div class="relative">
            <h2 class="font-heading text-3xl font-bold text-white">Csatlakozzon elégedett pácienseinkhez</h2>
            <p class="mt-4 text-gray-300 text-lg max-w-xl mx-auto">
              Foglaljon időpontot, és tapasztalja meg Ön is a különbséget.
            </p>
            <a href={`${base}kapcsolat#idopontfoglalas`} class="mt-8 inline-flex items-center justify-center px-10 py-4 bg-gold-500 hover:bg-gold-600 text-white font-bold text-lg rounded-full transition-all hover:shadow-xl hover:shadow-gold-500/25 hover:-translate-y-0.5">
              Időpontfoglalás
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
