---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Rólunk — McKenzie Gyógytorna Rendelő Budapest | 30+ év tapasztalat"
  description="Ismerje meg a McKenzie Gyógytorna Rendelő történetét. 1993 óta Magyarország egyetlen hivatalos McKenzie referenciarendelője, 18 képzett terapeutával."
>
  <!-- HERO -->
  <section class="relative pt-32 pb-24 lg:pb-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950 via-navy-900 to-navy-800"></div>

    <!-- Organic rings -->
    <svg class="absolute top-10 right-[5%] w-[400px] h-[400px] text-teal-400 opacity-[0.05] hero-drift" viewBox="0 0 400 400" fill="none">
      <circle cx="200" cy="200" r="170" stroke="currentColor" stroke-width="0.75"/>
      <circle cx="200" cy="200" r="125" stroke="currentColor" stroke-width="0.5"/>
    </svg>

    <!-- Ambient glow -->
    <div class="absolute top-1/3 right-1/4 w-[300px] h-[300px] bg-teal-600/[0.06] rounded-full blur-[100px]"></div>
    <div class="absolute bottom-1/4 left-[8%] w-[200px] h-[200px] bg-gold-500/[0.04] rounded-full blur-[80px]"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="reveal inline-flex items-center gap-3 px-5 py-2.5 border border-gold-400/20 rounded-full mb-8">
        <div class="w-1.5 h-1.5 bg-gold-400 rounded-full animate-pulse"></div>
        <span class="text-gold-300/80 text-xs tracking-[0.15em] uppercase font-medium">A rendelőről</span>
      </div>

      <h1 class="reveal stagger-1 font-heading text-4xl sm:text-5xl lg:text-[4.5rem] font-semibold text-white leading-[1.08]">
        30+ év a<br/><em class="font-normal text-gold-400">gyógyulás szolgálatában</em>
      </h1>

      <p class="reveal stagger-2 mt-6 text-teal-200/50 text-lg max-w-2xl mx-auto leading-relaxed">
        Magyarország egyetlen hivatalos McKenzie referenciarendelője. Nem csupán kezelünk — megtanítjuk, hogyan kezelje magát.
      </p>
    </div>
  </section>

  <!-- TÖRTÉNETÜNK -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
        <div class="reveal">
          <span class="text-gold-500 text-xs tracking-[0.2em] uppercase font-semibold">Történetünk</span>
          <h2 class="font-heading text-4xl sm:text-5xl font-semibold text-navy-900 mt-4 leading-tight">
            Ahol a szakértelem<br/>találkozik az odafigyeléssel
          </h2>
          <div class="w-10 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mt-5"></div>

          <p class="mt-8 text-navy-700/55 text-lg leading-relaxed">
            A McKenzie Gyógytorna Rendelőt <strong class="text-navy-900 font-semibold">Relle Éva</strong> alapította 1993-ban, azzal a céllal, hogy a nemzetközileg elismert McKenzie-módszert Magyarországon is elérhetővé tegye.
          </p>
          <p class="mt-4 text-navy-700/55 text-lg leading-relaxed">
            Azóta a rendelő Magyarország egyetlen hivatalos McKenzie referenciarendelőjévé vált, ahol <strong class="text-navy-900 font-semibold">18 képzett terapeuta</strong> dolgozik a páciensek gyógyulásáért.
          </p>
          <p class="mt-4 text-navy-700/55 text-lg leading-relaxed">
            Filozófiánk egyszerű: nem elég kezelni a fájdalmat — a páciensnek meg kell tanulnia, hogyan előzze meg annak visszatérését.
          </p>
        </div>

        <div class="reveal stagger-2 relative">
          <div class="aspect-[4/5] rounded-[2rem] overflow-hidden shadow-2xl shadow-navy-900/15 bg-warm-100">
            <img src={`${base}images/relle_eva.jpg`} alt="Relle Éva — a McKenzie Gyógytorna Rendelő alapítója" class="w-full h-full object-cover object-top" loading="lazy" />
          </div>
          <div class="absolute -bottom-5 -left-5 bg-white rounded-2xl shadow-lg shadow-navy-900/10 p-5 border border-warm-200/50">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-full bg-teal-50 flex items-center justify-center">
                <span class="text-teal-700 font-bold text-lg font-heading">93</span>
              </div>
              <div>
                <p class="font-semibold text-navy-900 text-sm">Alapítva</p>
                <p class="text-xs text-navy-700/40">1993, Budapest</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ÉRTÉKEINK -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="reveal text-gold-500 text-xs tracking-[0.2em] uppercase font-semibold">Értékeink</span>
        <h2 class="reveal stagger-1 font-heading text-4xl sm:text-5xl font-semibold text-navy-900 mt-4">
          Ami megkülönböztet minket
        </h2>
        <div class="w-10 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="reveal stagger-1 group bg-white rounded-2xl p-8 border border-warm-200/60 hover:border-teal-300/50 hover:shadow-lg hover:shadow-teal-600/[0.04] transition-all duration-500">
          <div class="w-12 h-12 rounded-2xl bg-teal-50 flex items-center justify-center mb-6 group-hover:bg-teal-100 transition-colors duration-300">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
          </div>
          <h3 class="font-heading text-2xl font-semibold text-navy-900">Evidencia-alapú</h3>
          <p class="mt-3 text-navy-700/50 leading-relaxed">
            Kizárólag tudományosan igazolt módszerekkel dolgozunk. A McKenzie-módszer az egyik legjobban kutatott fizikoterápiás megközelítés a világon.
          </p>
        </div>

        <div class="reveal stagger-2 group bg-white rounded-2xl p-8 border border-warm-200/60 hover:border-teal-300/50 hover:shadow-lg hover:shadow-teal-600/[0.04] transition-all duration-500">
          <div class="w-12 h-12 rounded-2xl bg-teal-50 flex items-center justify-center mb-6 group-hover:bg-teal-100 transition-colors duration-300">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
          </div>
          <h3 class="font-heading text-2xl font-semibold text-navy-900">Páciens-központú</h3>
          <p class="mt-3 text-navy-700/50 leading-relaxed">
            Minden páciens egyéni vizsgálatot és személyre szabott kezelési tervet kap. Az önkezelés megtanítása minden terápia központi eleme.
          </p>
        </div>

        <div class="reveal stagger-3 group bg-white rounded-2xl p-8 border border-warm-200/60 hover:border-teal-300/50 hover:shadow-lg hover:shadow-teal-600/[0.04] transition-all duration-500">
          <div class="w-12 h-12 rounded-2xl bg-teal-50 flex items-center justify-center mb-6 group-hover:bg-teal-100 transition-colors duration-300">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>
          </div>
          <h3 class="font-heading text-2xl font-semibold text-navy-900">Folyamatos képzés</h3>
          <p class="mt-3 text-navy-700/50 leading-relaxed">
            Minden terapeutánk McKenzie A-E szintű képzéssel rendelkezik, és rendszeresen vesz részt hazai és nemzetközi továbbképzéseken.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- IDŐVONAL / MÉRFÖLDKÖVEK -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-xl mb-16">
        <span class="reveal text-gold-500 text-xs tracking-[0.2em] uppercase font-semibold">Mérföldkövek</span>
        <h2 class="reveal stagger-1 font-heading text-4xl sm:text-5xl font-semibold text-navy-900 mt-4 leading-tight">
          Az eddigi utunk
        </h2>
        <div class="w-10 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mt-5"></div>
      </div>

      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-6 top-0 bottom-0 w-px bg-warm-200"></div>

        <div class="space-y-12">
          <div class="reveal relative pl-16">
            <div class="absolute left-0 w-12 h-12 rounded-full bg-navy-800 flex items-center justify-center">
              <span class="text-gold-400 font-heading font-bold text-sm">93</span>
            </div>
            <div>
              <span class="text-gold-500 text-xs tracking-[0.15em] uppercase font-semibold">1993</span>
              <h3 class="font-heading text-xl font-semibold text-navy-900 mt-1">A rendelő megalapítása</h3>
              <p class="mt-2 text-navy-700/50 leading-relaxed">Relle Éva megalapítja a McKenzie Gyógytorna Rendelőt és a Magyarországi McKenzie Intézetet, ezzel elhozva a McKenzie-módszert Magyarországra.</p>
            </div>
          </div>

          <div class="reveal relative pl-16">
            <div class="absolute left-0 w-12 h-12 rounded-full bg-teal-600 flex items-center justify-center">
              <span class="text-white font-heading font-bold text-sm">Ref</span>
            </div>
            <div>
              <span class="text-gold-500 text-xs tracking-[0.15em] uppercase font-semibold">Referenciarendelő</span>
              <h3 class="font-heading text-xl font-semibold text-navy-900 mt-1">Hivatalos McKenzie státusz</h3>
              <p class="mt-2 text-navy-700/50 leading-relaxed">A rendelő elnyeri a hivatalos McKenzie referenciarendelő státuszt — Magyarországon az egyetlen ilyen intézmény.</p>
            </div>
          </div>

          <div class="reveal relative pl-16">
            <div class="absolute left-0 w-12 h-12 rounded-full bg-navy-800 flex items-center justify-center">
              <span class="text-gold-400 font-heading font-bold text-xs">2</span>
            </div>
            <div>
              <span class="text-gold-500 text-xs tracking-[0.15em] uppercase font-semibold">Két helyszín</span>
              <h3 class="font-heading text-xl font-semibold text-navy-900 mt-1">Belvárosi és bel-budai rendelő</h3>
              <p class="mt-2 text-navy-700/50 leading-relaxed">Ma már két helyszínen — a Sas utcában és a Bartók Béla úton — fogadjuk pácienseinket, 18 képzett terapeutával.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RENDELŐK -->
  <section class="py-24 lg:py-32 bg-warm-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="reveal text-gold-500 text-xs tracking-[0.2em] uppercase font-semibold">Helyszíneink</span>
        <h2 class="reveal stagger-1 font-heading text-4xl sm:text-5xl font-semibold text-navy-900 mt-4">
          Két rendelő, egy színvonal
        </h2>
        <div class="w-10 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="reveal stagger-1 bg-white rounded-2xl p-8 lg:p-10 border border-warm-200/60 hover:shadow-lg transition-all duration-500">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-teal-50 flex items-center justify-center">
              <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            </div>
            <h3 class="font-heading text-2xl font-semibold text-navy-900">Belvárosi rendelő</h3>
          </div>
          <address class="not-italic space-y-3 text-navy-700/55">
            <p class="text-lg font-medium text-navy-900">1051 Budapest, Sas u. 7.</p>
            <p>Hétköznapokon 8:00–20:00</p>
            <a href="tel:+36304878284" class="inline-flex items-center gap-2 text-teal-600 font-semibold hover:text-teal-700 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              (30) 487-8284
            </a>
          </address>
          <p class="mt-5 text-sm text-navy-700/40">Deák Ferenc tér metró, Erzsébet tér villamosok közelében</p>
        </div>

        <div class="reveal stagger-2 bg-white rounded-2xl p-8 lg:p-10 border border-warm-200/60 hover:shadow-lg transition-all duration-500">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-teal-50 flex items-center justify-center">
              <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            </div>
            <h3 class="font-heading text-2xl font-semibold text-navy-900">Bel-budai rendelő</h3>
          </div>
          <address class="not-italic space-y-3 text-navy-700/55">
            <p class="text-lg font-medium text-navy-900">1111 Budapest, Bartók Béla út 34. I.em.1.</p>
            <p>Hétköznapokon 8:00–20:00</p>
            <a href="tel:+36304878284" class="inline-flex items-center gap-2 text-teal-600 font-semibold hover:text-teal-700 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              (30) 487-8284
            </a>
          </address>
          <p class="mt-5 text-sm text-navy-700/40">Gellért tér, Szent Gellért tér és Móricz Zsigmond körtér közelében</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SZÁMOK -->
  <section class="relative py-24 lg:py-32 bg-navy-900 overflow-hidden">
    <svg class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] text-teal-400 opacity-[0.04]" viewBox="0 0 500 500" fill="none">
      <circle cx="250" cy="250" r="220" stroke="currentColor" stroke-width="0.5"/>
      <circle cx="250" cy="250" r="160" stroke="currentColor" stroke-width="0.5"/>
    </svg>
    <div class="absolute top-10 right-[12%] w-[250px] h-[250px] bg-gold-500/[0.05] rounded-full blur-[80px]"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="reveal font-heading text-4xl sm:text-5xl font-semibold text-white">Számokban</h2>
        <div class="w-10 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mx-auto mt-5"></div>
      </div>

      <div class="reveal grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center">
          <span class="font-heading text-5xl lg:text-6xl font-semibold text-white">30+</span>
          <p class="mt-3 text-white/35 text-sm">év tapasztalat</p>
        </div>
        <div class="text-center">
          <span class="font-heading text-5xl lg:text-6xl font-semibold text-white">18</span>
          <p class="mt-3 text-white/35 text-sm">képzett terapeuta</p>
        </div>
        <div class="text-center">
          <span class="font-heading text-5xl lg:text-6xl font-semibold text-white">2</span>
          <p class="mt-3 text-white/35 text-sm">budapesti rendelő</p>
        </div>
        <div class="text-center">
          <span class="font-heading text-5xl lg:text-6xl font-semibold text-white">5.0</span>
          <div class="mt-3 flex items-center justify-center gap-1.5">
            <div class="flex -space-x-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <span class="text-white/35 text-sm">Google</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="reveal font-heading text-4xl sm:text-5xl font-semibold text-navy-900 leading-tight">
        Készen áll a<br/><em class="font-normal text-teal-600">fájdalommentes életre?</em>
      </h2>
      <p class="reveal stagger-1 mt-6 text-navy-700/50 text-lg max-w-xl mx-auto leading-relaxed">
        Foglaljon időpontot, és az első alkalommal közösen megtervezzük a kezelési tervet.
      </p>
      <div class="reveal stagger-2 mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}kapcsolat#idopontfoglalas`} class="inline-flex items-center justify-center px-10 py-4 bg-gold-500 hover:bg-gold-600 text-white font-semibold text-lg rounded-full transition-all duration-500 hover:shadow-xl hover:shadow-gold-500/20">
          Időpontfoglalás
        </a>
        <a href="tel:+36304878284" class="inline-flex items-center justify-center px-10 py-4 text-navy-700/60 font-medium text-lg border border-warm-200 rounded-full transition-all duration-500 hover:bg-white hover:border-teal-300/50 hover:text-navy-900">
          (30) 487-8284
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes heroDrift {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(8px, -6px) rotate(1deg); }
    66% { transform: translate(-4px, 4px) rotate(-0.5deg); }
  }
  .hero-drift {
    animation: heroDrift 20s ease-in-out infinite;
  }
</style>
