---

<BaseLayout
  title="Csapatunk — 18 képzett terapeuta | McKenzie Gyógytorna Rendelő Budapest"
  description="Ismerje meg a McKenzie Gyógytorna Rendelő teljes csapatát. 18 nemzetközileg képzett gyógytornász, McKenzie A-E szintű képesítéssel."
>
  <!-- HERO -->
  <section class="relative pt-32 pb-24 lg:pb-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950 via-navy-900 to-navy-800"></div>

    <!-- Organic ring -->
    <svg class="absolute top-10 right-[5%] w-[400px] h-[400px] text-teal-400 opacity-[0.05] hero-drift" viewBox="0 0 400 400" fill="none">
      <circle cx="200" cy="200" r="170" stroke="currentColor" stroke-width="0.75"/>
      <circle cx="200" cy="200" r="125" stroke="currentColor" stroke-width="0.5"/>
    </svg>

    <!-- Ambient glow -->
    <div class="absolute top-1/3 right-1/4 w-[300px] h-[300px] bg-teal-600/[0.06] rounded-full blur-[100px]"></div>
    <div class="absolute bottom-1/4 left-[8%] w-[200px] h-[200px] bg-gold-500/[0.04] rounded-full blur-[80px]"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="reveal inline-flex items-center gap-3 px-5 py-2.5 border border-gold-400/20 rounded-full mb-8">
        <div class="w-1.5 h-1.5 bg-gold-400 rounded-full animate-pulse"></div>
        <span class="text-gold-300/80 text-xs tracking-[0.15em] uppercase font-medium">A rendelő csapata</span>
      </div>

      <h1 class="reveal stagger-1 font-heading text-4xl sm:text-5xl lg:text-[4.5rem] font-semibold text-white leading-[1.08]">
        Minden terapeutánk<br/><em class="font-normal text-gold-400">McKenzie-képzett</em>
      </h1>

      <p class="reveal stagger-2 mt-6 text-teal-200/50 text-lg max-w-2xl mx-auto leading-relaxed">
        Nálunk nem véletlenszerűen kerül hozzá a pácienshez egy terapeuta. Minden kollégánk McKenzie-képzett, és folyamatosan továbbképzi magát.
      </p>

      <!-- Stats strip -->
      <div class="reveal stagger-3 mt-12 pt-8 border-t border-white/[0.06]">
        <div class="flex flex-wrap items-center justify-center gap-8 text-sm text-white/30">
          <div class="flex items-center gap-2">
            <span class="text-3xl font-semibold text-white font-heading">18</span>
            <span>gyógytornász</span>
          </div>
          <div class="w-px h-8 bg-white/10"></div>
          <div class="flex items-center gap-2">
            <span class="text-3xl font-semibold text-white font-heading">30+</span>
            <span>év tapasztalat</span>
          </div>
          <div class="w-px h-8 bg-white/10"></div>
          <div class="flex items-center gap-2">
            <span class="text-3xl font-semibold text-white font-heading">4</span>
            <span>nyelven fogadunk</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RELLE ÉVA — featured leader -->
  <section class="py-24 lg:py-32 bg-warm-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="reveal grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-12 lg:gap-16 items-start">
        <!-- Photo -->
        <div class="relative">
          <div class="aspect-[3/4] rounded-[2rem] overflow-hidden shadow-2xl shadow-navy-900/15">
            <img src={relleEva.photo} alt={relleEva.name} class="w-full h-full object-cover object-top" />
          </div>
          <!-- Experience badge -->
          <div class="absolute -bottom-4 -right-4 bg-white rounded-2xl shadow-lg shadow-navy-900/10 p-4 border border-warm-200/50">
            <div class="flex items-center gap-3">
              <div class="w-11 h-11 rounded-full bg-teal-50 flex items-center justify-center">
                <span class="text-teal-700 font-bold text-base font-heading">30+</span>
              </div>
              <div>
                <p class="font-semibold text-navy-900 text-sm">Év tapasztalat</p>
                <p class="text-xs text-navy-700/40">1993 óta</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Info -->
        <div>
          <span class="text-gold-500 text-xs tracking-[0.2em] uppercase font-semibold">A rendelő vezetője</span>
          <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-semibold text-navy-900 mt-3">{relleEva.name}</h2>
          <p class="text-teal-600 font-medium mt-2 text-lg">{relleEva.title}</p>
          <div class="w-10 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mt-5"></div>

          <p class="mt-6 text-navy-700/55 text-lg leading-relaxed">
            1993 óta a Magyarországi McKenzie Intézet vezetője. Nemzetközi McKenzie minősítő vizsgával, manuálterapeuta diplomával és több évtizedes tapasztalattal rendelkezik a gerinc eredetű fájdalmak kezelésében.
          </p>

          <div class="mt-8 pl-5 border-l-2 border-gold-400/40">
            <p class="text-navy-700/45 leading-relaxed italic font-heading text-xl">
              „Azt vallom, hogy a legjobb kezelés az, amit a páciens megtanul saját magának elvégezni."
            </p>
          </div>

          <div class="mt-8 flex flex-wrap gap-2">
            {relleEva.quals.map(q => (
              <span class="px-3.5 py-1.5 bg-teal-50 text-teal-700 border border-teal-200/50 rounded-full text-xs font-medium">{q}</span>
            ))}
          </div>

          {relleEva.langs.length > 0 && (
            <div class="mt-5 flex items-center gap-2 text-sm text-navy-700/40">
              <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>
              <span>Nyelvek: {relleEva.langs.join(', ')}</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM GRID -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-xl mb-16 lg:mb-20">
        <span class="reveal text-gold-500 text-xs tracking-[0.2em] uppercase font-semibold">Terapeutáink</span>
        <h2 class="reveal stagger-1 font-heading text-4xl sm:text-5xl font-semibold text-navy-900 mt-4 leading-tight">
          A teljes csapat
        </h2>
        <div class="w-10 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mt-5"></div>
        <p class="reveal stagger-2 mt-5 text-navy-700/50 text-lg leading-relaxed">
          Az első konzultáción kiválasztjuk az Önhöz legjobban illő szakembert.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {active.map((t, i) => (
          <div class={`reveal stagger-${(i % 3) + 1} group bg-warm-50 rounded-2xl overflow-hidden border border-warm-200/60 hover:border-teal-300/50 hover:shadow-lg hover:shadow-teal-600/[0.04] transition-all duration-500`}>
            <!-- Photo -->
            <div class="aspect-[4/5] overflow-hidden relative">
              <img src={t.photo} alt={t.name} class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-[1.03]" loading={i < 6 ? 'eager' : 'lazy'} />
              <!-- Price badge -->
              {t.price && (
                <div class="absolute bottom-3 right-3 bg-white/90 backdrop-blur-sm rounded-full px-3.5 py-1.5 shadow-sm">
                  <span class="text-navy-900 font-semibold text-sm">{t.price}</span>
                  <span class="text-navy-700/40 text-xs"> / alkalom</span>
                </div>
              )}
            </div>

            <div class="p-6">
              <h3 class="font-heading text-xl font-semibold text-navy-900 group-hover:text-teal-700 transition-colors duration-300">{t.name}</h3>
              <p class="text-teal-600 text-sm font-medium mt-1">{t.title}</p>

              <div class="mt-4 space-y-1.5 text-sm text-navy-700/45">
                {t.diploma && (
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-teal-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>
                    <span>Diploma: {t.diploma}</span>
                  </div>
                )}
                {t.langs.length > 0 && (
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-teal-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>
                    <span>{t.langs.join(', ')}</span>
                  </div>
                )}
              </div>

              <!-- Qualifications -->
              <details class="mt-4 group/details">
                <summary class="inline-flex items-center gap-1.5 text-sm text-teal-600 cursor-pointer hover:text-teal-700 select-none font-medium transition-colors">
                  <svg class="w-3.5 h-3.5 transition-transform duration-200 group-open/details:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  Képesítések ({t.quals.length})
                </summary>
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {t.quals.map(q => (
                    <span class="px-2.5 py-1 bg-white text-navy-700/55 border border-warm-200/50 rounded-full text-xs">{q}</span>
                  ))}
                </div>
              </details>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GYES -->
  {onLeave.length > 0 && (
    <section class="py-16 bg-warm-50">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="reveal text-center mb-10">
          <span class="text-navy-700/30 text-xs tracking-[0.2em] uppercase font-semibold">Jelenleg távol</span>
          <h3 class="font-heading text-2xl font-semibold text-navy-700/40 mt-2">Szülési szabadságon</h3>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {onLeave.map((t, i) => (
            <div class={`reveal stagger-${i + 1} flex items-center gap-4 p-5 bg-white/60 rounded-2xl border border-warm-200/40`}>
              <img src={t.photo} alt={t.name} class="w-14 h-14 rounded-full object-cover object-top grayscale opacity-60" loading="lazy" />
              <div>
                <p class="font-heading font-semibold text-navy-700/50">{t.name}</p>
                <p class="text-xs text-navy-700/30 mt-0.5">{t.title}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="relative py-24 lg:py-32 bg-navy-900 overflow-hidden">
    <svg class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] text-teal-400 opacity-[0.04]" viewBox="0 0 500 500" fill="none">
      <circle cx="250" cy="250" r="220" stroke="currentColor" stroke-width="0.5"/>
      <circle cx="250" cy="250" r="160" stroke="currentColor" stroke-width="0.5"/>
    </svg>
    <div class="absolute top-10 right-[12%] w-[250px] h-[250px] bg-gold-500/[0.05] rounded-full blur-[80px]"></div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="reveal font-heading text-4xl sm:text-5xl font-semibold text-white leading-tight">
        Melyik terapeutánkhoz<br/><em class="font-normal text-gold-400">szeretne jönni?</em>
      </h2>
      <p class="reveal stagger-1 mt-6 text-white/35 text-lg max-w-xl mx-auto leading-relaxed">
        Foglaljon időpontot, és az első alkalommal segítünk kiválasztani az Önhöz legjobban illő szakembert.
      </p>
      <div class="reveal stagger-2 mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}kapcsolat#idopontfoglalas`} class="inline-flex items-center justify-center px-10 py-4 bg-gold-500 hover:bg-gold-600 text-white font-semibold text-lg rounded-full transition-all duration-500 hover:shadow-xl hover:shadow-gold-500/20">
          Időpontfoglalás
        </a>
        <a href="tel:+36304878284" class="inline-flex items-center justify-center px-10 py-4 text-white/50 font-medium text-lg border border-white/10 rounded-full transition-all duration-500 hover:bg-white/[0.05] hover:border-white/15 hover:text-white/70">
          (30) 487-8284
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

