const active = terapeutak.filter(t => !t.status && t.name !== 'Relle Éva');
const onLeave = terapeutak.filter(t => t.status);
---

<BaseLayout
  title="Csapatunk — 18 képzett terapeuta | McKenzie Gyógytorna Rendelő Budapest"
  description="Ismerje meg a McKenzie Gyógytorna Rendelő teljes csapatát. 18 nemzetközileg képzett gyógytornász, McKenzie A-E szintű képesítéssel."
>
  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-teal-700"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    <div class="absolute top-20 right-10 w-72 h-72 bg-teal-500/10 rounded-full blur-3xl"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block text-teal-300 font-semibold text-sm tracking-widest uppercase mb-4">A rendelő csapata</span>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white">Minden terapeutánk<br/><span class="text-teal-300">McKenzie-képzett</span></h1>
      <p class="mt-6 text-gray-300 text-lg max-w-2xl mx-auto leading-relaxed">
        Nálunk nem véletlenszerűen kerül hozzá a pácienshez egy terapeuta. Minden kollégánk McKenzie-képzett, és folyamatosan továbbképzi magát.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-8 text-sm text-gray-400">
        <div class="flex items-center gap-2">
          <span class="text-2xl font-bold text-white font-heading">18</span>
          <span>gyógytornász</span>
        </div>
        <div class="w-px h-6 bg-white/20"></div>
        <div class="flex items-center gap-2">
          <span class="text-2xl font-bold text-white font-heading">30+</span>
          <span>év tapasztalat</span>
        </div>
        <div class="w-px h-6 bg-white/20"></div>
        <div class="flex items-center gap-2">
          <span class="text-2xl font-bold text-white font-heading">4</span>
          <span>nyelven fogadunk</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Relle Éva — featured -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="reveal grid grid-cols-1 md:grid-cols-[280px_1fr] gap-10 items-start">
        <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-xl">
          <img src={relleEva.photo} alt={relleEva.name} class="w-full h-full object-cover object-top" />
        </div>
        <div>
          <span class="text-teal-600 font-semibold text-sm tracking-widest uppercase">A rendelő vezetője</span>
          <h2 class="font-heading text-3xl sm:text-4xl font-bold text-navy-900 mt-2">{relleEva.name}</h2>
          <p class="text-teal-600 font-medium mt-1">{relleEva.title}</p>
          <p class="mt-4 text-gray-500 leading-relaxed">
            1993 óta a Magyarországi McKenzie Intézet vezetője. Nemzetközi McKenzie minősítő vizsgával, manuálterapeuta diplomával és több évtizedes tapasztalattal rendelkezik a gerinc eredetű fájdalmak kezelésében.
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            {relleEva.quals.map(q => (
              <span class="px-3 py-1.5 bg-teal-50 text-teal-700 rounded-full text-xs font-medium">{q}</span>
            ))}
          </div>
          {relleEva.langs.length > 0 && (
            <p class="mt-4 text-gray-400 text-sm">Nyelvek: {relleEva.langs.join(', ')}</p>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Team grid -->
  <section class="py-20 bg-warm-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="reveal font-heading text-3xl sm:text-4xl font-bold text-navy-900">Terapeutáink</h2>
        <p class="reveal stagger-1 mt-3 text-gray-500 text-lg">Az első konzultáción kiválasztjuk az Önhöz legjobban illő szakembert.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        {active.map((t, i) => (
          <div class={`reveal stagger-${(i % 3) + 1} bg-white rounded-2xl overflow-hidden border border-gray-100`}>
            <div class="aspect-[4/5] overflow-hidden">
              <img src={t.photo} alt={t.name} class="w-full h-full object-cover object-top" loading={i < 6 ? 'eager' : 'lazy'} />
            </div>
            <div class="p-5">
              <h3 class="font-heading text-lg font-bold text-navy-900">{t.name}</h3>
              <p class="text-teal-600 text-sm mt-0.5">{t.title}</p>

              <div class="mt-3 text-gray-500 text-sm leading-relaxed">
                {t.diploma && <p>Diploma: {t.diploma}</p>}
                {t.price && <p class="font-medium text-navy-900">{t.price} / alkalom</p>}
                {t.langs.length > 0 && <p>Nyelvek: {t.langs.join(', ')}</p>}
              </div>

              <details class="mt-3 group">
                <summary class="text-sm text-teal-600 cursor-pointer hover:text-teal-700 select-none">
                  Képesítések ({t.quals.length})
                </summary>
                <ul class="mt-2 space-y-0.5 text-gray-500 text-xs">
                  {t.quals.map(q => (
                    <li class="pl-3 relative before:content-['·'] before:absolute before:left-0 before:text-gray-400">{q}</li>
                  ))}
                </ul>
              </details>
            </div>
          </div>
        ))}
      </div>

      <!-- GYES -->
      {onLeave.length > 0 && (
        <div class="reveal border-t border-gray-200 pt-10">
          <h3 class="font-heading text-lg text-gray-400 mb-4">Jelenleg szülési szabadságon</h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {onLeave.map(t => (
              <div class="flex items-center gap-3 p-3 bg-white/50 rounded-xl opacity-50">
                <img src={t.photo} alt={t.name} class="w-12 h-12 rounded-full object-cover object-top" loading="lazy" />
                <div>
                  <p class="font-medium text-gray-600 text-sm">{t.name}</p>
                  <p class="text-xs text-gray-400">{t.title}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-teal-700"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="reveal font-heading text-3xl sm:text-4xl font-bold text-white">Melyik terapeutánkhoz szeretne jönni?</h2>
      <p class="reveal stagger-1 mt-4 text-gray-300 text-lg">Foglaljon időpontot, és az első alkalommal segítünk kiválasztani az Önhöz legjobban illő szakembert.</p>
      <a href="/kapcsolat#idopontfoglalas" class="reveal stagger-2 inline-flex items-center justify-center mt-8 px-10 py-4 bg-gold-500 hover:bg-gold-600 text-white font-bold text-lg rounded-full transition-all hover:shadow-xl hover:shadow-gold-500/25 hover:-translate-y-0.5">
        Időpontfoglalás
      </a>
    </div>
  </section>
</BaseLayout>
