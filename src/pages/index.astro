---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadMagnet from '../components/LeadMagnet.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="McKenzie Gyógytorna Rendelő Budapest | Referenciarendelő">

  <!-- HERO — Deep forest green, authoritative -->
  <section class="relative min-h-[85vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950 via-navy-900 to-navy-800"></div>

    <!-- Organic ring decoration -->
    <svg class="absolute top-16 right-[8%] w-[480px] h-[480px] text-teal-400 opacity-[0.05] hero-drift" viewBox="0 0 480 480" fill="none">
      <circle cx="240" cy="240" r="200" stroke="currentColor" stroke-width="0.75"/>
      <circle cx="240" cy="240" r="155" stroke="currentColor" stroke-width="0.5"/>
      <circle cx="240" cy="240" r="110" stroke="currentColor" stroke-width="0.5"/>
    </svg>

    <!-- Ambient glow -->
    <div class="absolute top-1/3 right-1/4 w-[350px] h-[350px] bg-teal-600/[0.06] rounded-full blur-[100px]"></div>
    <div class="absolute bottom-1/4 left-[10%] w-[250px] h-[250px] bg-gold-500/[0.04] rounded-full blur-[80px]"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 lg:py-40">
      <div class="max-w-2xl">
        <!-- Badge -->
        <div class="reveal inline-flex items-center gap-3 px-5 py-2.5 border border-gold-400/20 rounded-full mb-10">
          <div class="w-1.5 h-1.5 bg-gold-400 rounded-full animate-pulse"></div>
          <span class="text-gold-300/80 text-xs tracking-[0.15em] uppercase font-medium">McKenzie Referenciarendelő Budapest</span>
        </div>

        <h1 class="reveal stagger-1 font-heading text-5xl sm:text-6xl lg:text-[5.5rem] font-semibold text-white leading-[1.06]">
          Szakértő kezekben,<br/>
          <em class="text-gold-400 font-normal">a gyógyulás útján.</em>
        </h1>

        <p class="reveal stagger-2 mt-8 text-lg text-teal-200/50 leading-relaxed max-w-lg">
          25+ év tapasztalattal segítünk a derékfájás, nyakfájás és porckorongsérv kezelésében. Nemcsak kezelünk — megtanítjuk, hogyan kezelje magát.
        </p>

        <div class="reveal stagger-3 mt-10 flex flex-col sm:flex-row gap-4">
          <a href={`${base}kapcsolat#idopontfoglalas`} class="group inline-flex items-center justify-center px-9 py-4 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-full transition-all duration-500 hover:shadow-xl hover:shadow-gold-500/20">
            Időpontfoglalás
            <svg class="ml-2.5 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="tel:+36304878284" class="inline-flex items-center justify-center px-9 py-4 text-white/60 font-medium border border-white/10 rounded-full transition-all duration-500 hover:bg-white/[0.05] hover:border-white/15 hover:text-white/80">
            <svg class="mr-2 w-4 h-4 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            (30) 487-8284
          </a>
        </div>

        <!-- Trust strip -->
        <div class="reveal stagger-4 mt-16 pt-8 border-t border-white/[0.06]">
          <div class="flex flex-wrap items-center gap-8 text-sm text-white/30">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span>1-2 napon belül időpont</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="flex -space-x-0.5">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-3.5 h-3.5 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                ))}
              </div>
              <span>5.0 a Google-on</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              <span>Megtanítjuk, hogyan kezelje magát</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MÓDSZEREK -->
  <section id="modszerek" class="py-24 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-xl mb-16 lg:mb-20">
        <span class="reveal text-gold-500 text-xs tracking-[0.2em] uppercase font-semibold">Kezelési módszereink</span>
        <h2 class="reveal stagger-1 font-heading text-4xl sm:text-5xl font-semibold text-navy-900 mt-4 leading-tight">
          Bizonyítottan hatékony módszerek
        </h2>
        <div class="w-10 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mt-5"></div>
        <p class="reveal stagger-2 mt-5 text-navy-700/50 text-lg leading-relaxed">
          Nemzetközileg elismert eljárásokkal dolgozunk, amelyek az Ön aktív közreműködésére épülnek.
        </p>
      </div>

      <!-- McKenzie featured -->
      <div class="reveal mb-8">
        <div class="relative bg-navy-800 rounded-[2rem] p-10 lg:p-14 overflow-hidden">
          <svg class="absolute -right-10 -top-10 w-[300px] h-[300px] text-teal-400 opacity-[0.07]" viewBox="0 0 300 300" fill="none">
            <circle cx="150" cy="150" r="130" stroke="currentColor" stroke-width="0.75"/>
            <circle cx="150" cy="150" r="90" stroke="currentColor" stroke-width="0.5"/>
          </svg>
          <div class="relative max-w-2xl">
            <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-gold-500/15 border border-gold-400/15 rounded-full mb-6">
              <span class="text-gold-300 text-xs tracking-[0.1em] uppercase font-semibold">Fő szakterületünk</span>
            </span>
            <h3 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-semibold text-white leading-tight">
              McKenzie-módszer <em class="font-normal text-gold-400">(MDT)</em>
            </h3>
            <p class="mt-5 text-teal-200/50 text-lg leading-relaxed">
              A McKenzie-módszer lényege, hogy a páciens aktív résztvevője legyen saját gyógyulásának. Célzott gyakorlatokkal és önkezelési stratégiákkal tartós eredményeket érünk el — nem csupán kezelünk, hanem megtanítjuk a pácienst saját problémája kezelésére.
            </p>
            <div class="mt-8 flex flex-wrap gap-2">
              {['Derekfájás', 'Nyakfájás', 'Porckorongsérv', 'Isiász', 'Végtagfájdalom'].map(tag => (
                <span class="px-4 py-1.5 bg-white/[0.07] border border-white/[0.07] text-white/60 rounded-full text-sm">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Other methods -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="reveal stagger-1 group bg-warm-50 rounded-2xl p-8 border border-warm-200/60 hover:border-teal-300/50 hover:shadow-lg hover:shadow-teal-600/[0.04] transition-all duration-500">
          <div class="w-8 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mb-6 transition-all duration-500 group-hover:w-14"></div>
          <h3 class="font-heading text-2xl font-semibold text-navy-900">Manuálterápia</h3>
          <p class="mt-3 text-navy-700/50 leading-relaxed">Kézi technikákkal végzett vizsgálat és kezelés az ízületek mozgásterjedelmének helyreállítására és a fájdalom csökkentésére.</p>
        </div>
        <div class="reveal stagger-2 group bg-warm-50 rounded-2xl p-8 border border-warm-200/60 hover:border-teal-300/50 hover:shadow-lg hover:shadow-teal-600/[0.04] transition-all duration-500">
          <div class="w-8 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mb-6 transition-all duration-500 group-hover:w-14"></div>
          <h3 class="font-heading text-2xl font-semibold text-navy-900">Stabilizációs tréning</h3>
          <p class="mt-3 text-navy-700/50 leading-relaxed">A gerinc mély stabilizáló izmainak célzott erősítése, amely a tartós fájdalommentesség alapja.</p>
        </div>
        <div class="reveal stagger-3 group bg-warm-50 rounded-2xl p-8 border border-warm-200/60 hover:border-teal-300/50 hover:shadow-lg hover:shadow-teal-600/[0.04] transition-all duration-500">
          <div class="w-8 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mb-6 transition-all duration-500 group-hover:w-14"></div>
          <h3 class="font-heading text-2xl font-semibold text-navy-900">Schroth-terápia</h3>
          <p class="mt-3 text-navy-700/50 leading-relaxed">Speciális háromdimenziós gyakorlatsor gerincferdülés (scoliosis) kezelésére és a tartás javítására.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MIRE SPECIALIZÁLÓDTUNK -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="reveal text-gold-500 text-xs tracking-[0.2em] uppercase font-semibold">Miben segítünk</span>
        <h2 class="reveal stagger-1 font-heading text-4xl sm:text-5xl font-semibold text-navy-900 mt-4">
          Mire specializálódtunk
        </h2>
        <div class="w-10 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-10">
        <div class="reveal stagger-1 group cursor-default">
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-full bg-teal-100 flex items-center justify-center shrink-0 group-hover:bg-teal-200 transition-colors duration-300">
              <div class="w-2 h-2 rounded-full bg-teal-600"></div>
            </div>
            <div>
              <h3 class="font-heading text-xl font-semibold text-navy-900 group-hover:text-teal-700 transition-colors duration-300">Derekfájás kezelése</h3>
              <p class="mt-2 text-navy-700/45 text-sm leading-relaxed">A derékfájás az irodai dolgozók népbetegsége. Célzott McKenzie-gyakorlatokkal gyors javulás érhető el.</p>
            </div>
          </div>
        </div>
        <div class="reveal stagger-2 group cursor-default">
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-full bg-teal-100 flex items-center justify-center shrink-0 group-hover:bg-teal-200 transition-colors duration-300">
              <div class="w-2 h-2 rounded-full bg-teal-600"></div>
            </div>
            <div>
              <h3 class="font-heading text-xl font-semibold text-navy-900 group-hover:text-teal-700 transition-colors duration-300">Nyakfájás kezelése</h3>
              <p class="mt-2 text-navy-700/45 text-sm leading-relaxed">Nyaki fájdalom, fejfájás, szédülés — a helyes tartás és mozgás visszaállítása a megoldás kulcsa.</p>
            </div>
          </div>
        </div>
        <div class="reveal stagger-3 group cursor-default">
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-full bg-teal-100 flex items-center justify-center shrink-0 group-hover:bg-teal-200 transition-colors duration-300">
              <div class="w-2 h-2 rounded-full bg-teal-600"></div>
            </div>
            <div>
              <h3 class="font-heading text-xl font-semibold text-navy-900 group-hover:text-teal-700 transition-colors duration-300">Porckorongsérv</h3>
              <p class="mt-2 text-navy-700/45 text-sm leading-relaxed">A porckorongsérv nem jelent feltétlenül műtétet. Az esetek 80%-ában konzervatív kezeléssel gyógyítható.</p>
            </div>
          </div>
        </div>
        <div class="reveal stagger-1 group cursor-default">
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-full bg-teal-100 flex items-center justify-center shrink-0 group-hover:bg-teal-200 transition-colors duration-300">
              <div class="w-2 h-2 rounded-full bg-teal-600"></div>
            </div>
            <div>
              <h3 class="font-heading text-xl font-semibold text-navy-900 group-hover:text-teal-700 transition-colors duration-300">Sportrehabilitáció</h3>
              <p class="mt-2 text-navy-700/45 text-sm leading-relaxed">Sportsérülések utáni rehabilitáció és visszatérés a versenysportba, egyéni terv alapján.</p>
            </div>
          </div>
        </div>
        <div class="reveal stagger-2 group cursor-default">
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-full bg-teal-100 flex items-center justify-center shrink-0 group-hover:bg-teal-200 transition-colors duration-300">
              <div class="w-2 h-2 rounded-full bg-teal-600"></div>
            </div>
            <div>
              <h3 class="font-heading text-xl font-semibold text-navy-900 group-hover:text-teal-700 transition-colors duration-300">Tartásjavítás</h3>
              <p class="mt-2 text-navy-700/45 text-sm leading-relaxed">Ülőmunka, telefon- és laptophasználat okozta tartásproblémák korrekciója.</p>
            </div>
          </div>
        </div>
        <div class="reveal stagger-3 group cursor-default">
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-full bg-teal-100 flex items-center justify-center shrink-0 group-hover:bg-teal-200 transition-colors duration-300">
              <div class="w-2 h-2 rounded-full bg-teal-600"></div>
            </div>
            <div>
              <h3 class="font-heading text-xl font-semibold text-navy-900 group-hover:text-teal-700 transition-colors duration-300">Műtét utáni rehabilitáció</h3>
              <p class="mt-2 text-navy-700/45 text-sm leading-relaxed">Gerinc- és ízületi műtétek utáni szakszerű rehabilitáció a teljes felépülésig.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RELLE ÉVA -->
  <section class="py-24 lg:py-32 bg-warm-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
        <div class="reveal order-2 lg:order-1">
          <span class="text-gold-500 text-xs tracking-[0.2em] uppercase font-semibold">Vezető terapeutánk</span>
          <h2 class="font-heading text-4xl sm:text-5xl font-semibold text-navy-900 mt-4">Relle Éva</h2>
          <div class="w-10 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mt-5"></div>

          <p class="mt-8 text-navy-700/60 text-lg leading-relaxed">
            25+ éves tapasztalattal rendelkező McKenzie-terapeuta, a rendelő alapítója és vezetője. Nemzetközi McKenzie diplomás (A–D szint), Magyarország egyetlen hivatalos McKenzie referenciarendelőjének vezetője.
          </p>

          <div class="mt-8 pl-5 border-l-2 border-gold-400/40">
            <p class="text-navy-700/45 leading-relaxed italic font-heading text-xl">
              „Azt vallom, hogy a legjobb kezelés az, amit a páciens megtanul saját magának elvégezni. Célom, hogy minden betegem önállóan is tudja kezelni panaszait."
            </p>
          </div>

          <div class="mt-8 flex flex-wrap gap-2.5">
            <span class="px-4 py-2 bg-white rounded-full text-sm text-navy-800 font-medium border border-warm-200">McKenzie Dip. MDT</span>
            <span class="px-4 py-2 bg-white rounded-full text-sm text-navy-800 font-medium border border-warm-200">25+ év tapasztalat</span>
            <span class="px-4 py-2 bg-white rounded-full text-sm text-navy-800 font-medium border border-warm-200">Angol, német nyelv</span>
          </div>

          <a href={`${base}csapatunk`} class="mt-8 inline-flex items-center gap-2 text-teal-600 font-semibold hover:text-teal-700 transition-colors group">
            A teljes csapat megtekintése
            <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>

        <div class="reveal stagger-2 order-1 lg:order-2 relative">
          <div class="aspect-[4/5] rounded-[2rem] overflow-hidden shadow-2xl shadow-navy-900/15">
            <img src={`${base}images/relle_eva.jpg`} alt="Relle Éva - McKenzie Gyógytorna Rendelő alapítója" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-5 -left-5 bg-white rounded-2xl shadow-lg shadow-navy-900/10 p-5 border border-warm-200/50">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-full bg-teal-50 flex items-center justify-center">
                <span class="text-teal-700 font-bold text-lg font-heading">17</span>
              </div>
              <div>
                <p class="font-semibold text-navy-900 text-sm">Terapeuta</p>
                <p class="text-xs text-navy-700/40">a csapatban</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VÉLEMÉNYEK -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="reveal text-gold-500 text-xs tracking-[0.2em] uppercase font-semibold">Vélemények</span>
        <h2 class="reveal stagger-1 font-heading text-4xl sm:text-5xl font-semibold text-navy-900 mt-4">
          Amit rólunk mondanak
        </h2>
        <div class="reveal stagger-2 flex items-center justify-center gap-3 mt-5">
          <div class="flex -space-x-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <span class="text-navy-700/40 text-sm">5.0 — Google értékelések alapján</span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="reveal relative bg-warm-50 rounded-2xl p-8 border border-warm-200/60 hover:shadow-lg transition-all duration-500">
          <span class="font-heading text-7xl text-gold-300/25 leading-none absolute top-4 right-6 select-none">"</span>
          <blockquote class="relative text-navy-700/55 leading-relaxed mt-2">
            „Mostanában semmi bajom. Mégis jövök. Miért? Kelleni kell valakinek. Testileg is, lelkileg is."
          </blockquote>
          <div class="mt-8 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-teal-100 flex items-center justify-center text-teal-700 font-bold text-sm">HH</div>
            <div>
              <p class="font-semibold text-navy-900 text-sm">Havas Henrik</p>
              <p class="text-xs text-navy-700/40">újságíró</p>
            </div>
          </div>
        </div>

        <div class="reveal stagger-1 relative bg-warm-50 rounded-2xl p-8 border border-warm-200/60 hover:shadow-lg transition-all duration-500">
          <span class="font-heading text-7xl text-gold-300/25 leading-none absolute top-4 right-6 select-none">"</span>
          <blockquote class="relative text-navy-700/55 leading-relaxed mt-2">
            „Itt megtanultam, hogy a porckorongsérv nem reménytelen helyzet. Őszintén ajánlom mindenkinek!"
          </blockquote>
          <div class="mt-8 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gold-100 flex items-center justify-center text-gold-600 font-bold text-sm">KK</div>
            <div>
              <p class="font-semibold text-navy-900 text-sm">Kulcsár Krisztián</p>
              <p class="text-xs text-navy-700/40">világbajnok vívó</p>
            </div>
          </div>
        </div>

        <div class="reveal stagger-2 relative bg-warm-50 rounded-2xl p-8 border border-warm-200/60 hover:shadow-lg transition-all duration-500">
          <span class="font-heading text-7xl text-gold-300/25 leading-none absolute top-4 right-6 select-none">"</span>
