---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadMagnet from '../components/LeadMagnet.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
---

<BaseLayout title="McKenzie Gyógytorna Rendelő Budapest | Referenciarendelő">

  <!-- HERO -->
  <section class="relative min-h-[65vh] flex items-center overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-teal-700"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>

    <!-- Floating accent shapes -->
    <div class="absolute top-20 right-10 w-72 h-72 bg-teal-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 left-10 w-96 h-96 bg-gold-500/10 rounded-full blur-3xl"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="max-w-3xl mx-auto text-center">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full border border-white/10 mb-8">
          <div class="w-2 h-2 bg-gold-400 rounded-full animate-pulse"></div>
          <span class="text-gold-300 text-sm font-medium">McKenzie Gyógytorna Rendelő Budapest</span>
        </div>

        <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-[1.1]">
          Szakértő kezekben<br/>
          <span class="text-teal-300">a gyógyulás útján</span>
        </h1>

        <p class="mt-8 text-lg sm:text-xl text-gray-300 leading-relaxed max-w-2xl mx-auto">
          25+ év tapasztalattal segítünk a derékfájás, nyakfájás és porckorongsérv kezelésében. Nemcsak kezelünk — megtanítjuk, hogyan kezelje magát.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/kapcsolat#idopontfoglalas" class="inline-flex items-center justify-center px-8 py-4 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-full text-lg transition-all hover:shadow-xl hover:shadow-gold-500/25 hover:-translate-y-0.5">
            Időpontfoglalás
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="tel:+36304878284" class="inline-flex items-center justify-center px-8 py-4 bg-white/10 hover:bg-white/20 backdrop-blur-sm text-white font-semibold rounded-full text-lg border border-white/20 transition-all hover:-translate-y-0.5">
            <svg class="mr-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            (30) 487-8284
          </a>
        </div>

        <!-- Trust line -->
        <div class="mt-12 flex flex-wrap items-center justify-center gap-6 text-sm text-gray-400">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>1-2 napon belül időpont</span>
          </div>
          <div class="w-px h-4 bg-gray-700"></div>
          <div class="flex items-center gap-2">
            <div class="flex -space-x-1">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <span>5.0 a Google-on</span>
          </div>
          <div class="w-px h-4 bg-gray-700"></div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <span>Megtanítjuk, hogyan kezelje magát</span>
          </div>
        </div>
      </div>
    </div>

  </section>

  <!-- MÓDSZEREK -->
  <section id="modszerek" class="py-28 bg-warm-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-20">
        <span class="reveal text-teal-600 font-semibold text-sm tracking-widest uppercase">Kezelési módszereink</span>
        <h2 class="reveal stagger-1 font-heading text-4xl sm:text-5xl font-bold text-navy-900 mt-3 gold-line-center">
          Bizonyítottan hatékony módszerek
        </h2>
        <p class="reveal stagger-2 mt-6 text-gray-500 text-lg">
          Nemzetközileg elismert eljárásokkal dolgozunk, amelyek az Ön aktív közreműködésére épülnek.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- McKenzie - kiemelt -->
        <div class="reveal md:col-span-2 group relative bg-gradient-to-br from-navy-900 to-navy-800 rounded-3xl p-10 lg:p-14 overflow-hidden">
          <div class="absolute top-0 right-0 w-80 h-80 bg-teal-500/10 rounded-full blur-3xl"></div>
          <div class="relative">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-gold-500/20 rounded-full mb-6">
              <span class="text-gold-300 text-sm font-semibold">Fő szakterületünk</span>
            </div>
            <h3 class="font-heading text-3xl sm:text-4xl font-bold text-white">McKenzie-módszer (MDT)</h3>
            <p class="mt-4 text-gray-300 text-lg max-w-2xl leading-relaxed">
              A McKenzie-módszer lényege, hogy a páciens aktív résztvevője legyen saját gyógyulásának. Célzott gyakorlatokkal és önkezelési stratégiákkal tartós eredményeket érünk el — nem csupán kezelünk, hanem megtanítjuk a pácienst saját problémája kezelésére.
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              {['Derekfájás', 'Nyakfájás', 'Porckorongsérv', 'Isiász', 'Végtagfájdalom'].map(tag => (
                <span class="px-4 py-1.5 bg-white/10 text-white/80 rounded-full text-sm">{tag}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Other methods -->
        <div class="reveal stagger-1 group bg-white rounded-3xl p-8 lg:p-10 border border-gray-100 hover:border-teal-200 hover:shadow-xl hover:shadow-teal-500/5 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-teal-50 flex items-center justify-center">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-2V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11"/></svg>
          </div>
          <h3 class="font-heading text-2xl font-bold text-navy-900 mt-5">Manuálterápia</h3>
          <p class="mt-3 text-gray-500 leading-relaxed">Kézi technikákkal végzett vizsgálat és kezelés az ízületek mozgásterjedelmének helyreállítására és a fájdalom csökkentésére.</p>
        </div>
        <div class="reveal stagger-2 group bg-white rounded-3xl p-8 lg:p-10 border border-gray-100 hover:border-teal-200 hover:shadow-xl hover:shadow-teal-500/5 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-teal-50 flex items-center justify-center">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="font-heading text-2xl font-bold text-navy-900 mt-5">Stabilizációs tréning</h3>
          <p class="mt-3 text-gray-500 leading-relaxed">A gerinc mély stabilizáló izmainak célzott erősítése, amely a tartós fájdalommentesség alapja.</p>
        </div>
        <div class="reveal stagger-3 group bg-white rounded-3xl p-8 lg:p-10 border border-gray-100 hover:border-teal-200 hover:shadow-xl hover:shadow-teal-500/5 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-teal-50 flex items-center justify-center">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2C8 2 6 5 6 8c0 2 1 3.5 2 4.5V14h8v-1.5c1-1 2-2.5 2-4.5 0-3-2-6-6-6zM8 17h8M9 20h6"/></svg>
          </div>
          <h3 class="font-heading text-2xl font-bold text-navy-900 mt-5">Schroth-terápia</h3>
          <p class="mt-3 text-gray-500 leading-relaxed">Speciális háromdimenziós gyakorlatsor gerincferdülés (scoliosis) kezelésére és a tartás javítására.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MIRE SPECIALIZÁLÓDTUNK -->
  <section class="py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-20">
        <span class="reveal text-teal-600 font-semibold text-sm tracking-widest uppercase">Miben segítünk</span>
        <h2 class="reveal stagger-1 font-heading text-4xl sm:text-5xl font-bold text-navy-900 mt-3 gold-line-center">
          Mire specializálódtunk
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <div class="reveal stagger-1 group p-7 rounded-2xl border border-gray-100 hover:bg-teal-50 hover:border-teal-200 transition-all duration-300 cursor-default">
          <div class="w-11 h-11 rounded-lg bg-teal-50 group-hover:bg-white flex items-center justify-center transition-colors">
            <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2m0 14v2M5.5 7L7 8.5m10-1.5L15.5 8.5M4 12H2m20 0h-2M7 15.5L5.5 17m11-1.5L18 17M12 8a4 4 0 00-4 4c0 1.5.8 2.8 2 3.5V17h4v-1.5c1.2-.7 2-2 2-3.5a4 4 0 00-4-4z"/></svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-navy-900 mt-4">Derekfájás kezelése</h3>
          <p class="mt-2 text-gray-500 text-sm leading-relaxed">A derékfájás az irodai dolgozók népbetegsége. Célzott McKenzie-gyakorlatokkal gyors javulás érhető el.</p>
        </div>
        <div class="reveal stagger-2 group p-7 rounded-2xl border border-gray-100 hover:bg-teal-50 hover:border-teal-200 transition-all duration-300 cursor-default">
          <div class="w-11 h-11 rounded-lg bg-teal-50 group-hover:bg-white flex items-center justify-center transition-colors">
            <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2C10 2 9 4 9 6s1 3 3 5c2-2 3-3 3-5s-1-4-3-4zM9 11c-2 1-4 3-4 6 0 2 1 3 3 4h8c2-1 3-2 3-4 0-3-2-5-4-6"/></svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-navy-900 mt-4">Nyakfájás kezelése</h3>
          <p class="mt-2 text-gray-500 text-sm leading-relaxed">Nyaki fájdalom, fejfájás, szédülés — a helyes tartás és mozgás visszaállítása a megoldás kulcsa.</p>
        </div>
        <div class="reveal stagger-3 group p-7 rounded-2xl border border-gray-100 hover:bg-teal-50 hover:border-teal-200 transition-all duration-300 cursor-default">
          <div class="w-11 h-11 rounded-lg bg-teal-50 group-hover:bg-white flex items-center justify-center transition-colors">
            <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/><circle cx="12" cy="12" r="10" stroke-width="1.5"/></svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-navy-900 mt-4">Porckorongsérv</h3>
          <p class="mt-2 text-gray-500 text-sm leading-relaxed">A porckorongsérv nem jelent feltétlenül műtétet. Az esetek 80%-ában konzervatív kezeléssel gyógyítható.</p>
        </div>
        <div class="reveal stagger-1 group p-7 rounded-2xl border border-gray-100 hover:bg-teal-50 hover:border-teal-200 transition-all duration-300 cursor-default">
          <div class="w-11 h-11 rounded-lg bg-teal-50 group-hover:bg-white flex items-center justify-center transition-colors">
            <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-navy-900 mt-4">Sportrehabilitáció</h3>
          <p class="mt-2 text-gray-500 text-sm leading-relaxed">Sportsérülések utáni rehabilitáció és visszatérés a versenysportba, egyéni terv alapján.</p>
        </div>
        <div class="reveal stagger-2 group p-7 rounded-2xl border border-gray-100 hover:bg-teal-50 hover:border-teal-200 transition-all duration-300 cursor-default">
          <div class="w-11 h-11 rounded-lg bg-teal-50 group-hover:bg-white flex items-center justify-center transition-colors">
            <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v1m0 14v1m-7-8h1m14 0h1m-2.636-5.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707M17.657 17.657l.707.707"/></svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-navy-900 mt-4">Tartásjavítás</h3>
          <p class="mt-2 text-gray-500 text-sm leading-relaxed">Ülőmunka, telefon- és laptophasználat okozta tartásproblémák korrekciója.</p>
        </div>
        <div class="reveal stagger-3 group p-7 rounded-2xl border border-gray-100 hover:bg-teal-50 hover:border-teal-200 transition-all duration-300 cursor-default">
          <div class="w-11 h-11 rounded-lg bg-teal-50 group-hover:bg-white flex items-center justify-center transition-colors">
            <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342"/></svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-navy-900 mt-4">Műtét utáni rehabilitáció</h3>
          <p class="mt-2 text-gray-500 text-sm leading-relaxed">Gerinc- és ízületi műtétek utáni szakszerű rehabilitáció a teljes felépülésig.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- RELLE ÉVA + CSAPAT -->
  <section class="py-28 bg-warm-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <span class="text-teal-600 font-semibold text-sm tracking-widest uppercase">Vezető terapeutánk</span>
          <h2 class="font-heading text-4xl sm:text-5xl font-bold text-navy-900 mt-3 gold-line">Relle Éva</h2>
          <p class="mt-6 text-gray-600 text-lg leading-relaxed">
            25+ éves tapasztalattal rendelkező McKenzie-terapeuta, a rendelő alapítója és vezetője. Nemzetközi McKenzie diplomás (A–D szint), Magyarország egyetlen hivatalos McKenzie referenciarendelőjének vezetője.
          </p>
          <p class="mt-4 text-gray-500 leading-relaxed">
            „Azt vallom, hogy a legjobb kezelés az, amit a páciens megtanul saját magának elvégezni. Célom, hogy minden betegem önállóan is tudja kezelni panaszait."
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <span class="px-4 py-2 bg-white rounded-full text-sm text-navy-900 font-medium shadow-sm">McKenzie Dip. MDT</span>
            <span class="px-4 py-2 bg-white rounded-full text-sm text-navy-900 font-medium shadow-sm">25+ év tapasztalat</span>
            <span class="px-4 py-2 bg-white rounded-full text-sm text-navy-900 font-medium shadow-sm">Angol, német nyelv</span>
          </div>
          <a href="/csapatunk" class="mt-8 inline-flex items-center gap-2 text-teal-600 font-semibold hover:text-teal-700 transition-colors group">
            A teljes csapat megtekintése
            <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>

        <div class="reveal stagger-2 relative">
          <div class="aspect-[4/5] rounded-3xl overflow-hidden shadow-2xl">
            <img src="/images/relle_eva.jpg" alt="Relle Éva - McKenzie Gyógytorna Rendelő alapítója" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <!-- Floating stats -->
          <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl p-5">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-full bg-gold-100 flex items-center justify-center">
                <span class="text-gold-600 font-bold text-lg">17</span>
              </div>
              <div>
                <p class="font-semibold text-navy-900">Terapeuta</p>
                <p class="text-xs text-gray-500">a csapatban</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VÉLEMÉNYEK -->
  <section class="py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-20">
        <span class="reveal text-teal-600 font-semibold text-sm tracking-widest uppercase">Vélemények</span>
        <h2 class="reveal stagger-1 font-heading text-4xl sm:text-5xl font-bold text-navy-900 mt-3 gold-line-center">
          Amit rólunk mondanak
        </h2>
        <div class="reveal stagger-2 flex items-center justify-center gap-2 mt-6">
          <div class="flex -space-x-1">
            {[1,2,3,4,5].map(() => (
              <svg class="w-6 h-6 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <span class="text-gray-500 font-medium">5.0 — Google értékelések alapján</span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="reveal bg-warm-50 rounded-3xl p-8 border border-gray-100">
          <div class="flex items-center gap-1 mb-4">
