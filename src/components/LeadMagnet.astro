---
// Lead Magnet: Ingyenes reggeli torna & tartásjavítási program
---

<section class="py-28 bg-gradient-to-br from-teal-700 via-teal-600 to-teal-500 relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 30px 30px;"></div>
  <div class="absolute -top-20 -right-20 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-gold-500/10 rounded-full blur-3xl"></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Tartalom -->
      <div class="reveal">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full border border-white/20 mb-6">
          <span class="text-gold-300 text-sm font-semibold">Ingyenes program</span>
        </div>
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-white leading-tight">
          5 napos reggeli torna<br/>
          <span class="text-teal-200">& tartásjavítási program</span>
        </h2>
        <p class="mt-6 text-teal-100 text-lg leading-relaxed">
          Kapjon egy ingyenes, személyre szabott 5 napos programot emailben, amely segít:
        </p>
        <ul class="mt-5 space-y-3">
          {[
            'Reggeli gerinctorna — 10 perces rutin minden napra',
            'Tartásjavító gyakorlatok irodai munkásoknak',
            'McKenzie alapgyakorlatok derekfájás ellen',
            'Önellenőrző teszt — mikor kell szakemberhez fordulni',
            'Ergonómiai tippek az ülőmunkához',
          ].map(item => (
            <li class="flex items-start gap-3 text-white/90">
              <svg class="w-5 h-5 text-gold-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Form -->
      <div class="reveal stagger-2">
        <div class="bg-white rounded-3xl p-8 shadow-2xl">
          <h3 class="font-heading text-2xl font-bold text-navy-900 text-center">
            Töltse le ingyen!
          </h3>
          <p class="text-gray-500 text-sm text-center mt-2">
            Adja meg email címét, és azonnal küldjük a programot.
          </p>

          <form id="lead-magnet-form" class="mt-6 space-y-4" data-netlify="true" name="lead-magnet" method="POST">
            <input type="hidden" name="form-name" value="lead-magnet" />
            <div>
              <label for="lm-name" class="block text-sm font-medium text-gray-700 mb-1">Keresztnév</label>
              <input
                type="text"
                id="lm-name"
                name="name"
                required
                placeholder="pl. Anna"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition-all text-gray-900 placeholder:text-gray-400"
              />
            </div>
            <div>
              <label for="lm-email" class="block text-sm font-medium text-gray-700 mb-1">Email cím</label>
              <input
                type="email"
                id="lm-email"
                name="email"
                required
                placeholder="anna@pelda.hu"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition-all text-gray-900 placeholder:text-gray-400"
              />
            </div>
            <div class="flex items-start gap-2">
              <input type="checkbox" id="lm-newsletter" name="newsletter" class="mt-1 rounded border-gray-300 text-teal-600 focus:ring-teal-500" />
              <label for="lm-newsletter" class="text-xs text-gray-500">
                Feliratkozom a heti hírlevélre is (hasznos tippek, gyakorlatok, akciók). Bármikor leiratkozhatok.
              </label>
            </div>
            <button
              type="submit"
              class="w-full px-6 py-4 bg-gold-500 hover:bg-gold-600 text-white font-bold text-lg rounded-xl transition-all hover:shadow-lg hover:shadow-gold-500/25 hover:-translate-y-0.5"
            >
              Kérem az ingyenes programot
            </button>
            <p class="text-xs text-gray-400 text-center">
              Nem küldünk spam-et. Az adatkezelési tájékoztató <a href="/adatvedelmi-tajekoztato" class="underline hover:text-gray-600">itt</a> olvasható.
            </p>
          </form>

          <!-- Success message (hidden by default) -->
          <div id="lead-magnet-success" class="hidden text-center py-8">
            <div class="w-16 h-16 mx-auto bg-teal-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h4 class="font-heading text-xl font-bold text-navy-900">Köszönjük!</h4>
            <p class="text-gray-600 mt-2">Elküldtük a programot az email címére. Nézze meg a bejövő üzeneteit!</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('lead-magnet-form') as HTMLFormElement;
  const success = document.getElementById('lead-magnet-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    try {
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(formData as any).toString(),
      });
      form.style.display = 'none';
      success?.classList.remove('hidden');
    } catch (err) {
      alert('Hiba történt, kérjük próbálja újra.');
    }
  });
</script>
