---
const currentPath = Astro.url.pathname;
const isHomePage = currentPath === '/';
const navLinks = [
  { href: '/modszerek', label: 'Módszerek' },
  { href: '/csapatunk', label: 'Csapatunk' },
  { href: '/araink', label: 'Áraink' },
  { href: '/velemenyek', label: 'Vélemények' },
  { href: '/gyik', label: 'GYIK' },
  { href: '/blog', label: 'Blog' },
  { href: '/kapcsolat', label: 'Kapcsolat' },
];
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" data-dark-hero={isHomePage ? 'true' : 'false'}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <img src="/images/logo.png" alt="McKenzie Rendelő logó" class="w-10 h-10 rounded-lg object-contain navbar-logo transition-all duration-300" />
        <div class="hidden sm:block">
          <span class="text-lg font-heading font-bold text-white navbar-scrolled:text-navy-900 transition-colors">McKenzie Rendelő</span>
          <span class="block text-xs text-teal-300 navbar-scrolled:text-teal-600 font-medium tracking-wider uppercase transition-colors">Referenciarendelő</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navLinks.map(link => (
          <a href={link.href} class="px-3 py-2 text-sm font-medium text-white/80 navbar-scrolled:text-gray-600 hover:text-white navbar-scrolled:hover:text-teal-700 transition-colors rounded-lg hover:bg-white/10 navbar-scrolled:hover:bg-teal-50">
            {link.label}
          </a>
        ))}
        <a href="/kapcsolat#idopontfoglalas" class="ml-3 px-5 py-2.5 bg-gold-500 hover:bg-gold-600 text-white text-sm font-semibold rounded-full transition-all hover:shadow-lg hover:shadow-gold-500/25 hover:-translate-y-0.5">
          Időpontfoglalás
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-lg text-white navbar-scrolled:text-gray-700" aria-label="Menü">
        <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white shadow-xl border-t border-gray-100">
    <div class="px-4 py-6 space-y-1">
      {navLinks.map(link => (
        <a href={link.href} class="block px-4 py-3 text-gray-700 hover:text-teal-700 hover:bg-teal-50 rounded-xl font-medium transition-colors">
          {link.label}
        </a>
      ))}
      <div class="pt-3">
        <a href="/kapcsolat#idopontfoglalas" class="block text-center px-6 py-3 bg-gold-500 hover:bg-gold-600 text-white font-semibold rounded-full transition-colors">
          Időpontfoglalás
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Scroll effect
  const navbar = document.getElementById('navbar');
  const hasDarkHero = navbar?.dataset.darkHero === 'true';

  const onScroll = () => {
    if (!hasDarkHero || window.scrollY > 50) {
      navbar?.classList.add('bg-white/95', 'backdrop-blur-lg', 'shadow-sm', 'scrolled');
      navbar?.classList.remove('bg-transparent');
    } else {
      navbar?.classList.remove('bg-white/95', 'backdrop-blur-lg', 'shadow-sm', 'scrolled');
      navbar?.classList.add('bg-transparent');
    }
  };
  window.addEventListener('scroll', onScroll);
  onScroll();

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>

<style>
  /* Override text colors when scrolled */
  #navbar.scrolled a:not([class*="bg-gold"]) {
    --tw-text-opacity: 1;
  }
  #navbar.scrolled .navbar-scrolled\:text-navy-900 { color: var(--color-navy-900); }
  #navbar.scrolled .navbar-scrolled\:text-teal-600 { color: var(--color-teal-600); }
  #navbar.scrolled .navbar-scrolled\:text-gray-600 { color: #4b5563; }
  #navbar.scrolled .navbar-scrolled\:text-gray-700 { color: #374151; }
  #navbar.scrolled .navbar-scrolled\:hover\:text-teal-700:hover { color: var(--color-teal-700); }
  #navbar.scrolled .navbar-scrolled\:hover\:bg-teal-50:hover { background-color: var(--color-teal-50); }
  #navbar.scrolled .navbar-logo { filter: invert(1); }
</style>
